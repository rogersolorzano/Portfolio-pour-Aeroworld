      <aliases enabled='yes' />
      <column caption='KPI Projets entreprise' datatype='integer' name='[Calculation_0700944095887361]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [type_projet] = &quot;Entreprise&quot;&#13;&#10;THEN [project_id]&#13;&#10;END)' />
      </column>
      <column caption='KPI Projets ecole' datatype='integer' name='[Calculation_0700944096284674]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [type_projet] = &quot;Ecole&quot;&#13;&#10;THEN [project_id]&#13;&#10;END)' />
      </column>
      <column caption='timeline_row' datatype='string' name='[Calculation_0700944099647491]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [type_projet] = &quot;Entreprise&quot;&#13;&#10;THEN &quot;Entreprise&quot;&#13;&#10;ELSE &quot;Formation&quot;&#13;&#10;END' />
      </column>
      <column caption='KPI Nombre Projets' datatype='integer' name='[Calculation_0700944104255492]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([project_id])' />
      </column>
      <column caption='KPI outils' datatype='integer' name='[Calculation_0700944104620037]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([tool_id (tools)])' />
      </column>
      <column caption='KPI compétences' datatype='integer' name='[Calculation_0700944105406470]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([skill_id (skills)])' />
      </column>
      <column caption='Durée Projet' datatype='integer' name='[Calculation_0700944120938503]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[date_debut],[date_fin])' />
      </column>
      <column caption='Couleur Timeline' datatype='string' name='[Calculation_0700944121102344]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [type_projet] = &quot;Entreprise&quot;&#13;&#10;THEN &quot;Entreprise&quot;&#13;&#10;ELSE &quot;École&quot;&#13;&#10;END' />
      </column>
      <column caption='Tool_couleur' datatype='integer' name='[Calculation_0700944140566538]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([tool_id])' />
      </column>
      <column caption='Usage_Professionnel_Label' datatype='string' name='[Calculation_0700944201658379]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [usage_professionnel] = &quot;TRUE&quot;&#13;&#10;THEN&#13;&#10;&quot;Utilisé en contexte professionnel&quot;&#13;&#10;ELSE&#13;&#10;&quot;Utilisé en contexte académique&quot;&#13;&#10;END' />
      </column>
      <column caption='Projet Label' datatype='string' name='[Calculation_0700944244224012]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[projet] + CHAR(10) + [domaine]' />
      </column>
      <column caption='Blank' datatype='string' name='[Calculation_0700944621895695]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;&quot;' />
      </column>
      <column caption='Texte Instruction UX' datatype='string' name='[Calculation_0700944889262100]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF TOTAL(COUNTD([projet])) &gt; 1 THEN &#13;&#10;    &quot;Sélectionnez un projet dans la liste pour voir les détails.&quot;&#13;&#10;ELSE &#13;&#10;    &quot;&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
